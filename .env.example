# Database (MySQL via Prisma)
# Format: mysql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="mysql://user:password@localhost:3306/haveninlipa"

# NextAuth.js
# Generate a secret: openssl rand -base64 32
NEXTAUTH_SECRET="replace-with-a-random-32-char-string"
NEXTAUTH_URL="http://localhost:3000"

# Vercel Blob Storage (for property images)
BLOB_READ_WRITE_TOKEN="vercel_blob_rw_..."

# Email — Resend (primary, for transactional emails)
RESEND_API_KEY="re_..."

# Stripe (payment processing)
STRIPE_SECRET_KEY="sk_test_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."

# Note: All transactional emails (booking notifications, contact form) use Resend.
# SMTP/Nodemailer is not used. Only RESEND_API_KEY is required for email.
