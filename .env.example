# Database (MySQL via Prisma)
# Format: mysql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="mysql://user:password@localhost:3306/haveninlipa"

# NextAuth.js
# Generate a secret: openssl rand -base64 32
NEXTAUTH_SECRET="replace-with-a-random-32-char-string"
NEXTAUTH_URL="http://localhost:3000"

# Vercel Blob Storage (for property images)
BLOB_READ_WRITE_TOKEN="vercel_blob_rw_..."

# Email — Hostinger SMTP (transactional emails: booking notifications, contact form)
SMTP_HOST="smtp.hostinger.com"
SMTP_PORT="465"
SMTP_USER="customerservice@haveninlipa.com"
SMTP_PASS="your-hostinger-email-password"

# Stripe (payment processing)
STRIPE_SECRET_KEY="sk_test_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."

# Cron job security (optional but recommended)
# Generate: openssl rand -base64 32
# Add to Vercel env vars — Vercel passes this as Authorization: Bearer <secret> when invoking crons
CRON_SECRET="replace-with-a-random-32-char-string"

# QR Integrity (generated by: npm run qr:hash)
# Re-run the script any time you replace a QR image
NEXT_PUBLIC_QR_HASH_GCASH="sha256-..."
NEXT_PUBLIC_QR_HASH_BPI="sha256-..."

# SMS — Twilio for outbound + 2-way inbound (Guest Messaging Phase 2)
# Sign up at twilio.com; buy a number under Phone Numbers → Buy a Number that supports
# SMS to/from the Philippines (a US long code or toll-free works; +63 local numbers
# are not generally available on Twilio).
# In dev, sends are logged to console unless SMS_FORCE_SEND=1 is set.
TWILIO_ACCOUNT_SID="AC..."
TWILIO_AUTH_TOKEN=""
TWILIO_FROM_NUMBER="+15555550123"        # E.164; this is the number used to send and receive
# SMS_FORCE_SEND="1"                     # uncomment to send real SMS in non-prod (e.g. staging)

# SMS inbound webhook — configure in Twilio console:
#   Phone Numbers → Active Numbers → <your number> → Messaging Configuration
#   "A message comes in" → Webhook → POST →
#   https://haveninlipa.com/api/sms/inbound?secret=<SMS_INBOUND_SECRET>
# Two layers of auth: shared `secret` query (below) AND Twilio's X-Twilio-Signature
# (verified automatically when TWILIO_AUTH_TOKEN is set above).
# Generate URL-safe (no +/= chars that break query-string parsing): openssl rand -hex 32
SMS_INBOUND_SECRET="replace-with-a-random-64-char-hex-string"

# Optional override — set ONLY if a reverse proxy rewrites the host on the way in.
# Twilio computes its signature against the URL it called; if NextRequest.url shows
# the wrong host (e.g. internal Vercel URL), set this to the public URL Twilio knows.
# TWILIO_WEBHOOK_URL="https://haveninlipa.com/api/sms/inbound?secret=..."

# SMS quiet hours (Asia/Manila, 24h). Defaults: 21..8 (i.e. don't send 9pm–8am).
# SMS_QUIET_HOURS_START="21"
# SMS_QUIET_HOURS_END="8"

# Email reply polling (Hostinger IMAP) — Phase 2 inbound for guest email replies
# Re-uses Hostinger creds. If IMAP_USER/IMAP_PASS are unset, falls back to SMTP_USER/SMTP_PASS.
IMAP_HOST="imap.hostinger.com"
IMAP_PORT="993"
IMAP_USER="customerservice@haveninlipa.com"
IMAP_PASS="your-hostinger-email-password"
# IMAP_MAILBOX="INBOX"   # optional — defaults to INBOX
