# Database (MySQL via Prisma)
# Format: mysql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="mysql://user:password@localhost:3306/cedcas"

# NextAuth.js
# Generate a secret: openssl rand -base64 32
NEXTAUTH_SECRET="replace-with-a-random-32-char-string"
NEXTAUTH_URL="http://localhost:3000"

# Vercel Blob Storage (for property images)
BLOB_READ_WRITE_TOKEN="vercel_blob_rw_..."

# Email — Resend (primary, for transactional emails)
RESEND_API_KEY="re_..."

# Email — SMTP fallback (optional, Nodemailer)
# SMTP_HOST="smtp.example.com"
# SMTP_PORT="587"
# SMTP_USER="user@example.com"
# SMTP_PASS="password"
